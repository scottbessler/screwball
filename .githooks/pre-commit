#!/bin/sh
# Repo pre-commit hook. Enable with: git config core.hooksPath .githooks
# (or run `mise run setup`). Bypass once with `git commit --no-verify`.
set -e

echo "[pre-commit] cargo fmt --check"
cargo fmt --check || {
	echo "  -> formatting issues. Run: mise run fix (or cargo fmt)" >&2
	exit 1
}

echo "[pre-commit] cargo clippy"
cargo clippy --all-targets

echo "[pre-commit] oxlint"
bun run lint

echo "[pre-commit] ok"
